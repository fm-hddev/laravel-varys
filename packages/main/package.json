    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "electron": "^30.0.0",
    "patch-package": "^8.0.1",
